# ============================================================
# .env.example — Variáveis de Ambiente
# ============================================================
# NUNCA suba o .env real para o GitHub!
# Copie este arquivo: cp .env.example .env
# Preencha com seus valores reais.
# O python-decouple lê este arquivo automaticamente.
# ============================================================

# SEGURANÇA — Gere uma chave nova com:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-troca-esta-chave-em-producao!

# Em produção: False
DEBUG=True

# Separe múltiplos hosts por vírgula
# Em produção: seudominio.com,www.seudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Superusuário inicial
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_EMAIL=admin@lanchopro.com
